<Window x:Class="SerialGuiApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="터보펌프 계측 제어 GUI (Serial Demo)" Height="600" Width="820"
        MinHeight="560" MinWidth="760">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 연결 설정 영역 -->
        <GroupBox Header="포트 연결" Grid.Row="0" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" Margin="8">
                <TextBlock Text="포트:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox x:Name="PortComboBox" Width="100" Margin="0,0,12,0"/>
                <Button x:Name="RefreshPortsButton" Content="새로고침" Width="80" Click="RefreshPortsButton_Click" Margin="0,0,20,0"/>

                <TextBlock Text="Baud Rate:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox x:Name="BaudRateComboBox" Width="90" Margin="0,0,20,0">
                    <ComboBoxItem Content="9600" IsSelected="True"/>
                    <ComboBoxItem Content="19200"/>
                    <ComboBoxItem Content="38400"/>
                    <ComboBoxItem Content="57600"/>
                    <ComboBoxItem Content="115200"/>
                </ComboBox>

                <Button x:Name="ConnectButton" Content="연결" Width="90" Click="ConnectButton_Click"/>

                <Ellipse x:Name="StatusLight" Width="14" Height="14" Fill="Gray" Margin="20,0,6,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="StatusText" Text="연결 안 됨" VerticalAlignment="Center" FontWeight="Bold"/>
            </StackPanel>
        </GroupBox>

        <!-- 텔레메트리 표시 + 명령 버튼 -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Header="터보펌프 텔레메트리 (Telemetry)" Grid.Column="0" Margin="0,0,6,0">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="온도 (°C):" Grid.Row="0" Grid.Column="0" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TempValueText" Text="--" Grid.Row="0" Grid.Column="1" FontSize="20" VerticalAlignment="Center"/>

                    <TextBlock Text="압력 (kPa):" Grid.Row="1" Grid.Column="0" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock x:Name="PressureValueText" Text="--" Grid.Row="1" Grid.Column="1" FontSize="20" VerticalAlignment="Center"/>

                    <TextBlock Text="밸브 상태:" Grid.Row="2" Grid.Column="0" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock x:Name="ValveStateText" Text="--" Grid.Row="2" Grid.Column="1" FontSize="20" VerticalAlignment="Center"/>

                    <TextBlock Text="마지막 수신:" Grid.Row="3" Grid.Column="0" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock x:Name="LastUpdateText" Text="--" Grid.Row="3" Grid.Column="1" VerticalAlignment="Center" Foreground="Gray"/>
                </Grid>
            </GroupBox>

            <GroupBox Header="명령 (Telecommand)" Grid.Column="1" Margin="6,0,0,0">
                <StackPanel Margin="10">
                    <Button x:Name="GetTempButton" Content="온도 조회 (GET:TEMP)" Height="34" Margin="0,0,0,8" Click="GetTempButton_Click" IsEnabled="False"/>
                    <Button x:Name="GetPressureButton" Content="압력 조회 (GET:PRESSURE)" Height="34" Margin="0,0,0,8" Click="GetPressureButton_Click" IsEnabled="False"/>
                    <Button x:Name="ValveOpenButton" Content="밸브 열기 (SET:VALVE:OPEN)" Height="34" Margin="0,0,0,8" Click="ValveOpenButton_Click" IsEnabled="False"/>
                    <Button x:Name="ValveCloseButton" Content="밸브 닫기 (SET:VALVE:CLOSE)" Height="34" Click="ValveCloseButton_Click" IsEnabled="False"/>
                </StackPanel>
            </GroupBox>
        </Grid>

        <!-- 통신 로그 -->
        <GroupBox Header="통신 로그" Grid.Row="2">
            <DockPanel Margin="8">
                <Button DockPanel.Dock="Bottom" Content="로그 지우기" Width="100" HorizontalAlignment="Right" Margin="0,8,0,0" Click="ClearLogButton_Click"/>
                <ListBox x:Name="LogListBox" FontFamily="Consolas" FontSize="12"/>
            </DockPanel>
        </GroupBox>
    </Grid>
</Window>
